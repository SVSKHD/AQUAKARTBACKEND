{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": ["airbnb-base"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "warn",
    "consistent-return": "warn",
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    "func-names": "off",
    "object-shorthand": "warn",
    "class-methods-use-this": "warn",
    "no-param-reassign": "warn",
    "prefer-destructuring": "warn"
  }
}
